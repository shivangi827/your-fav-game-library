{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/server.ts", "src/db.ts", "src/feedback-sheets.ts", "src/feedback-email.ts", "src/games/**/shared/*.ts", "src/games/**/server.ts", "src/games/**/sheets.ts"],
  "exclude": ["src/games/**/client"]
}
